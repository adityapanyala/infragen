resource "aws_security_group" "alb" {
  name        = "{{ project_name }}-alb-sg"
  description = "Security group for {{ project_name }} ALB"
  vpc_id      = aws_vpc.main.id

  ingress {
    description = "HTTP"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    description = "HTTPS"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name        = "{{ project_name }}-alb-sg"
    project     = "{{ project_name }}"
    environment = "{{ environment }}"
    managed_by  = "infragen"
  }
}

resource "aws_security_group" "ecs" {
  name        = "{{ project_name }}-ecs-sg"
  description = "Security group for {{ project_name }} ECS tasks"
  vpc_id      = aws_vpc.main.id

  ingress {
    description     = "App port from ALB only"
    from_port       = {{ port }}
    to_port         = {{ port }}
    protocol        = "tcp"
    security_groups = [aws_security_group.alb.id]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name        = "{{ project_name }}-ecs-sg"
    project     = "{{ project_name }}"
    environment = "{{ environment }}"
    managed_by  = "infragen"
  }
}

{% if needs_rds %}
resource "aws_security_group" "rds" {
  name        = "{{ project_name }}-rds-sg"
  description = "Security group for {{ project_name }} RDS"
  vpc_id      = aws_vpc.main.id

  ingress {
    description     = "DB from ECS only"
    from_port       = {{ '5432' if rds_engine == 'postgres' else '3306' }}
    to_port         = {{ '5432' if rds_engine == 'postgres' else '3306' }}
    protocol        = "tcp"
    security_groups = [aws_security_group.ecs.id]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name        = "{{ project_name }}-rds-sg"
    project     = "{{ project_name }}"
    environment = "{{ environment }}"
    managed_by  = "infragen"
  }
}
{% endif %}

{% if needs_elasticache %}
resource "aws_security_group" "elasticache" {
  name        = "{{ project_name }}-elasticache-sg"
  description = "Security group for {{ project_name }} ElastiCache"
  vpc_id      = aws_vpc.main.id

  ingress {
    description     = "Redis from ECS only"
    from_port       = 6379
    to_port         = 6379
    protocol        = "tcp"
    security_groups = [aws_security_group.ecs.id]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name        = "{{ project_name }}-elasticache-sg"
    project     = "{{ project_name }}"
    environment = "{{ environment }}"
    managed_by  = "infragen"
  }
}
{% endif %}
