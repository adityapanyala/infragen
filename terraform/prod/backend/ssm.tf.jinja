{% for key in secret_vars %}
resource "aws_ssm_parameter" "secret_{{ key | lower | replace('-', '_') | replace('.', '_') }}" {
  name  = "/{{ project_name }}/{{ environment }}/{{ key }}"
  type  = "SecureString"
  value = "PLACEHOLDER"

  lifecycle {
    ignore_changes = [value]
  }

  tags = {
    project    = "{{ project_name }}"
    managed_by = "infragen"
  }
}
{% endfor %}

{% for key in config_vars %}
resource "aws_ssm_parameter" "config_{{ key | lower | replace('-', '_') | replace('.', '_') }}" {
  name  = "/{{ project_name }}/{{ environment }}/{{ key }}"
  type  = "String"
  value = "PLACEHOLDER"

  lifecycle {
    ignore_changes = [value]
  }

  tags = {
    project    = "{{ project_name }}"
    managed_by = "infragen"
  }
}
{% endfor %}

{% if needs_rds %}
resource "aws_ssm_parameter" "db_password" {
  name  = "/{{ project_name }}/{{ environment }}/DB_PASSWORD"
  type  = "SecureString"
  value = random_password.db_password.result

  tags = {
    project    = "{{ project_name }}"
    managed_by = "infragen"
  }
}
{% endif %}
