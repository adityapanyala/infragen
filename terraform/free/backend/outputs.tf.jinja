output "app_public_ip" {
  description = "Public IP of the EC2 instance"
  value       = aws_eip.app.public_ip
}

output "app_endpoint" {
  description = "Application endpoint URL"
  value       = "http://${aws_eip.app.public_ip}:{{ port }}"
}

output "ssh_command" {
  description = "SSH command to connect to the instance"
  value       = "ssh -i infragen-{{ project_name }}.pem ec2-user@${aws_eip.app.public_ip}"
}

output "ecr_repository_url" {
  description = "ECR repository URL"
  value       = aws_ecr_repository.app.repository_url
}

{% if needs_rds %}
output "rds_endpoint" {
  description = "RDS instance endpoint"
  value       = aws_db_instance.main.endpoint
}

output "db_password_ssm_path" {
  description = "SSM path where DB password is stored"
  value       = "/{{ project_name }}/{{ environment }}/DB_PASSWORD"
}
{% endif %}
